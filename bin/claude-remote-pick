#!/usr/bin/env bash
set -uo pipefail
# Resolve symlinks so HERE points at the real script dir (install.sh symlinks
# this into ~/.local/bin; the lib lives next to the real script, not the link).
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  HERE="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [ "${SOURCE#/}" = "$SOURCE" ] && SOURCE="$HERE/$SOURCE"
done
HERE="$(cd -P "$(dirname "$SOURCE")" && pwd)"
# shellcheck source=../lib/claude-remote-lib.sh disable=SC1091
. "${HERE}/../lib/claude-remote-lib.sh"
# An SSH forced command runs with a minimal PATH; make our tools resolvable.
cr_augment_path

# --list: print menu lines (session<TAB>display) + footnote, then exit.
if [ "${1:-}" = "--list" ]; then
  cr_menu_lines
  exit 0
fi

# Interactive loop: render menu, read a choice, attach (no exec → return here on detach).
# Uses fzf when available and stdout is a terminal; otherwise a numbered menu.
while true; do
  tmpd="$(mktemp -d)"
  cr_menu_lines >"${tmpd}/menu" 2>"${tmpd}/foot" || true
  menu=()
  while IFS= read -r line; do [ -n "$line" ] && menu+=("$line"); done <"${tmpd}/menu"
  footnote=""
  [ -s "${tmpd}/foot" ] && footnote="$(cat "${tmpd}/foot")"
  rm -rf "${tmpd}"

  # Pass the menu lines as args, but never inject a spurious empty arg when the
  # menu is empty (would break ${#menu[@]} under bash 3.2 + set -u in a forced cmd).
  if [ "${#menu[@]}" -gt 0 ]; then
    pick_args=("$footnote" "${menu[@]}")
  else
    pick_args=("$footnote")
  fi
  if command -v fzf >/dev/null 2>&1 && [ -t 1 ]; then
    selection="$(cr_pick_fzf "${pick_args[@]}")"
  else
    selection="$(cr_pick_numbered "${pick_args[@]}")"
  fi

  case "$selection" in
    __QUIT__ | "") exit 0 ;;
    __NONE__) : ;; # invalid choice → redraw
    __NEW__)
      printf "Verzeichnis (leer = \$HOME): " >&2
      read -r dir || dir=""
      dir="${dir:-$HOME}"
      # Subshell: cr_launch execs `tmux attach`; running it in ( ) means the exec
      # replaces only the subshell, so the picker loop survives a detach here too.
      (cd "$dir" && cr_launch "$(cr_session_name "")" 1 --)
      ;;
    *)
      # shellcheck disable=SC2086
      $CR_TMUX attach -t "$selection"
      ;;
  esac
done
