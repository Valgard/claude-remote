#!/usr/bin/env bash
set -uo pipefail
# Resolve symlinks so HERE points at the real script dir (install.sh symlinks
# this into ~/.local/bin; the lib lives next to the real script, not the link).
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  HERE="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [ "${SOURCE#/}" = "$SOURCE" ] && SOURCE="$HERE/$SOURCE"
done
HERE="$(cd -P "$(dirname "$SOURCE")" && pwd)"
# shellcheck source=../lib/claude-remote-lib.sh disable=SC1091
. "${HERE}/../lib/claude-remote-lib.sh"
# An SSH forced command runs with a minimal PATH; make our tools resolvable.
cr_augment_path

# --list: print menu lines (session<TAB>display) + footnote, then exit.
if [ "${1:-}" = "--list" ]; then
  cr_menu_lines
  exit 0
fi

# --ensure-anchor: create the hidden holding session that keeps the tmux server
# alive in a keychain-capable (Aqua) launchd namespace, then exit. Invoked by the
# install.sh LaunchAgent at GUI login. Runs after cr_augment_path, so tmux resolves
# under launchd's minimal PATH exactly as it does under the SSH forced command.
if [ "${1:-}" = "--ensure-anchor" ]; then
  cr_ensure_anchor
  exit $?
fi

# Interactive loop: render menu, read a choice, attach (no exec → return here on detach).
# Uses fzf when available and stdout is a terminal; otherwise a numbered menu.
# Interactive output goes to a terminal, so colourise (fzf gets --ansi; the numbered
# menu prints to the terminal directly). --list stays plain (CR_COLOR unset).
export CR_COLOR=1
while true; do
  tmpd="$(mktemp -d)"
  cr_menu_lines >"${tmpd}/menu" 2>"${tmpd}/foot" || true
  menu=()
  while IFS= read -r line; do [ -n "$line" ] && menu+=("$line"); done <"${tmpd}/menu"
  footnote=""
  [ -s "${tmpd}/foot" ] && footnote="$(cat "${tmpd}/foot")"
  rm -rf "${tmpd}"

  # Pass the menu lines as args, but never inject a spurious empty arg when the
  # menu is empty (would break ${#menu[@]} under bash 3.2 + set -u in a forced cmd).
  if [ "${#menu[@]}" -gt 0 ]; then
    pick_args=("$footnote" "${menu[@]}")
  else
    pick_args=("$footnote")
  fi
  if command -v fzf >/dev/null 2>&1 && [ -t 1 ]; then
    selection="$(cr_pick_fzf "${pick_args[@]}")"
  else
    selection="$(cr_pick_numbered "${pick_args[@]}")"
  fi

  case "$selection" in
    __QUIT__ | "") exit 0 ;;
    __NONE__ | __RELOAD__) : ;; # invalid choice or refresh → redraw (re-runs cr_menu_lines)
    __NEW__)
      # `read -e` enables readline line editing: arrow keys move within the line
      # (over SSH from e.g. an iPad the cursor keys otherwise leak raw ESC[C/ESC[D
      # bytes into the buffer). readline activates only on a terminal, so piped/test
      # input still behaves like a plain read. `-p` lets readline own the prompt so
      # its redraw stays aligned while editing (prompt still goes to stderr).
      read -e -r -p "$(printf 'Verzeichnis (leer = %s): ' "$CR_NEW_DIR")" input || input=""
      # cr_resolve_new_dir applies the ergonomic shortcut (a bare name -> a project
      # under CR_NEW_DIR) plus ~/$HOME expansion, tagging the result bare|path. A
      # missing bare-name dir is offered for creation; a missing explicit path is
      # still rejected (no surprising mkdir of a mistyped absolute path).
      IFS=$'\t' read -r kind dir <<<"$(cr_resolve_new_dir "$input")"
      if [ ! -d "$dir" ]; then
        if [ "$kind" = bare ]; then
          read -r -p "$(printf 'Verzeichnis %s existiert nicht. Anlegen? [j/N] ' "$dir")" yn || yn=""
          case "$yn" in
            j | J | y | Y)
              mkdir -p "$dir" || {
                printf "Konnte %s nicht anlegen\n" "$dir" >&2
                continue
              }
              ;;
            *) continue ;;
          esac
        else
          printf "Kein Verzeichnis: %s\n" "$dir" >&2
          continue
        fi
      fi
      # Subshell: cr_launch execs `tmux attach`; running it in ( ) means the exec
      # replaces only the subshell, so the picker loop survives a detach here too.
      (cd "$dir" && cr_launch "$(cr_session_name "")" 1 --)
      ;;
    *)
      # shellcheck disable=SC2086
      $CR_TMUX attach -t "$selection"
      ;;
  esac
done
