#!/usr/bin/env bash
# cr-sign-tmux — rebuild the installed tmux from source with an embedded Info.plist
# (CFBundleIdentifier + NSLocalNetworkUsageDescription) and ad-hoc code-sign it.
#
# Why: macOS Local Network privacy checks the whole parent process chain and
# silently blocks LAN access ("no route to host") when an unidentified binary sits
# in the chain. Homebrew's tmux carries no Info.plist, so a picker-born session
# (… -> tmux -> git/ssh) cannot reach LAN hosts (e.g. a git remote on the LAN)
# while public internet still works. Embedding an Info.plist with an
# NSLocalNetworkUsageDescription turns tmux into an "identified app": macOS then
# lists it under System Settings > Privacy & Security > Local Network and can grant
# it (and its children) LAN access. tmux is already ad-hoc signed by Homebrew, so
# signing alone is not enough — the Info.plist is the missing piece.
#
# Re-run after `brew upgrade tmux` (Homebrew overwrites the patched binary).
#
# Usage:
#   cr-sign-tmux           build + sign + install over the current tmux (with backup)
#   cr-sign-tmux --check   report whether the installed tmux is already patched
set -euo pipefail

BUNDLE_ID="${CR_TMUX_BUNDLE_ID:-com.github.tmux}"
TMUX_BIN="${CR_TMUX_BIN:-$(command -v tmux || true)}"

die() {
  printf 'cr-sign-tmux: %s\n' "$1" >&2
  exit 1
}

# Resolve a symlink chain to the real file (Homebrew links bin/ -> Cellar/).
# Portable (no readlink -f): mirrors the symlink-safe resolution in the bins.
real_path() {
  local p="$1" t
  while [ -L "$p" ]; do
    t="$(readlink "$p")"
    case "$t" in
      /*) p="$t" ;;
      *) p="$(dirname "$p")/$t" ;;
    esac
  done
  printf '%s\n' "$p"
}

has_info_plist() {
  otool -l "$1" 2>/dev/null | grep -q "__info_plist"
}

[ -n "$TMUX_BIN" ] || die "kein tmux im PATH gefunden"
REAL_TMUX="$(real_path "$TMUX_BIN")"
[ -f "$REAL_TMUX" ] || die "tmux-Binary nicht gefunden: $REAL_TMUX"

# --check: report patched/unpatched, change nothing.
if [ "${1:-}" = "--check" ]; then
  if has_info_plist "$REAL_TMUX"; then
    echo "OK: tmux trägt eine eingebettete Info.plist (Local Network möglich): $REAL_TMUX"
    exit 0
  fi
  echo "FEHLT: tmux ohne Info.plist (Local Network blockiert): $REAL_TMUX"
  exit 1
elif [ "$#" -gt 0 ]; then
  die "unbekanntes Argument: $1 (nutze: --check oder ohne Argument)"
fi

command -v codesign >/dev/null || die "codesign fehlt (Xcode Command Line Tools?)"
command -v otool >/dev/null || die "otool fehlt (Xcode Command Line Tools?)"
command -v brew >/dev/null || die "brew fehlt (Homebrew?)"

VER="$("$TMUX_BIN" -V 2>/dev/null | awk '{print $2}')"
[ -n "$VER" ] || die "tmux-Version nicht ermittelbar"
case "$VER" in
  *next* | *master*) die "nur Release-Versionen haben einen Quell-Tarball; gefunden: '$VER'" ;;
esac

EVENT_PREFIX="$(brew --prefix libevent)"
NCURSES_PREFIX="$(brew --prefix ncurses)"
UTF8_PREFIX="$(brew --prefix utf8proc)"

WORK="$(mktemp -d)"
trap 'rm -rf "$WORK"' EXIT
LOG="${WORK}/build.log"

echo "→ lade tmux ${VER} Quelltext …" >&2
URL="https://github.com/tmux/tmux/releases/download/${VER}/tmux-${VER}.tar.gz"
curl -fSL --retry 2 -o "${WORK}/tmux.tar.gz" "$URL" || die "Download fehlgeschlagen: $URL"
tar -xzf "${WORK}/tmux.tar.gz" -C "$WORK"
SRC="${WORK}/tmux-${VER}"
[ -d "$SRC" ] || die "entpackter Quellordner fehlt: $SRC"

cat >"${SRC}/Info.plist" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleIdentifier</key>
  <string>${BUNDLE_ID}</string>
  <key>CFBundleName</key>
  <string>tmux</string>
  <key>NSLocalNetworkUsageDescription</key>
  <string>tmux relays connections (git, ssh) from terminal sessions to hosts on your local network.</string>
</dict>
</plist>
PLIST

echo "→ konfiguriere & baue (utf8proc + sixel wie Homebrew) …" >&2
if ! (
  cd "$SRC"
  export PKG_CONFIG_PATH="${EVENT_PREFIX}/lib/pkgconfig:${NCURSES_PREFIX}/lib/pkgconfig:${UTF8_PREFIX}/lib/pkgconfig:${PKG_CONFIG_PATH:-}"
  export CPPFLAGS="-I${NCURSES_PREFIX}/include ${CPPFLAGS:-}"
  ./configure \
    --enable-sixel \
    --enable-utf8proc \
    LDFLAGS="-L${NCURSES_PREFIX}/lib -Wl,-sectcreate,__TEXT,__info_plist,Info.plist"
  make -j"$(sysctl -n hw.ncpu)"
) >"$LOG" 2>&1; then
  tail -40 "$LOG" >&2
  die "Build fehlgeschlagen (Log oben)"
fi

BUILT="${SRC}/tmux"
[ -x "$BUILT" ] || die "Build erzeugte kein tmux-Binary"

# Verify before touching the installed binary: version match, plist embedded,
# and the new binary actually starts a server (isolated socket, no user config).
BUILT_VER="$("$BUILT" -V | awk '{print $2}')"
[ "$BUILT_VER" = "$VER" ] || die "Versionsmismatch: gebaut ${BUILT_VER}, erwartet ${VER}"
has_info_plist "$BUILT" || die "Info.plist wurde nicht eingebettet"
SOCK="cr_signtest_$$"
"$BUILT" -L "$SOCK" -f /dev/null new-session -d 'sleep 5' 2>/dev/null || die "Smoke-Test fehlgeschlagen (neuer tmux startet nicht)"
"$BUILT" -L "$SOCK" kill-server 2>/dev/null || true

echo "→ ad-hoc signieren …" >&2
codesign -s - -f "$BUILT" >/dev/null 2>&1 || die "codesign fehlgeschlagen"

# Install over the real (Cellar) binary, keeping a one-time original backup.
# Homebrew keeps its binaries read-only but in a user-owned dir, so replacing
# in place needs no sudo (rm + cp in a writable dir); fall back to sudo only if
# even the directory is read-only.
BACKUP="${REAL_TMUX}.cr-orig"
install_file() { # <src> <dst>
  if [ -w "$2" ]; then
    cp "$1" "$2"
  elif [ -w "$(dirname "$2")" ]; then
    rm -f "$2" && cp "$1" "$2"
  else
    sudo cp "$1" "$2"
  fi
}
[ -e "$BACKUP" ] || install_file "$REAL_TMUX" "$BACKUP"
install_file "$BUILT" "$REAL_TMUX"
chmod +x "$REAL_TMUX" 2>/dev/null || true

cat >&2 <<DONE

✓ tmux ${VER} neu gebaut, signiert und installiert: ${REAL_TMUX}
  (Original-Backup: ${BACKUP})

Aktivieren — ⚠️ beendet ALLE laufenden tmux-Sessions:
    tmux kill-server
Danach neu verbinden. Beim ersten LAN-Zugriff zeigt macOS am Mac den
„Lokales Netzwerk"-Dialog → Erlauben. tmux erscheint dann unter
Systemeinstellungen → Datenschutz & Sicherheit → Lokales Netzwerk.

Nach jedem brew-Upgrade von tmux erneut ausführen:  make sign-tmux
DONE
