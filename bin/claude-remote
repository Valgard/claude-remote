#!/usr/bin/env bash
set -euo pipefail
# Resolve symlinks so HERE points at the real script dir (install.sh symlinks
# this into ~/.local/bin; the lib lives next to the real script, not the link).
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  HERE="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [ "${SOURCE#/}" = "$SOURCE" ] && SOURCE="$HERE/$SOURCE"
done
HERE="$(cd -P "$(dirname "$SOURCE")" && pwd)"
# shellcheck source=../lib/claude-remote-lib.sh disable=SC1091
. "${HERE}/../lib/claude-remote-lib.sh"
# An SSH forced command (or other stripped env) has a minimal PATH; make tools resolvable.
cr_augment_path
# The same stripped env lacks LANG/LC_*; pin a UTF-8 locale so the launched
# claude pane handles multibyte (UTF-8) input/paste instead of mangling it.
cr_ensure_utf8_locale

usage() {
  cat >&2 <<'EOF'
Usage: claude-remote [-l|--label LABEL] [--no-attach] [-- CLAUDE_ARGS...]
Launches claude inside a named, persistent tmux session and attaches.
EOF
}

label=""
attach=1
while [ $# -gt 0 ]; do
  case "$1" in
    -l | --label)
      if [ $# -lt 2 ]; then
        echo "claude-remote: -l/--label requires an argument" >&2
        exit 1
      fi
      label="$2"
      shift 2
      ;;
    --no-attach)
      attach=0
      shift
      ;;
    -h | --help)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    *) break ;;
  esac
done

# Heads-up if the session won't be reachable remotely yet. Read-only, no sudo;
# the session still launches. Self-extinguishes once Remote Login is enabled.
if ! cr_sshd_running; then
  echo "claude-remote: ⚠️  Remote Login (sshd) ist aus — diese Session ist nur lokal erreichbar." >&2
  echo "             Aktivieren: sudo systemsetup -setremotelogin on" >&2
fi

# Reap stale post-exit captures up front (drain no longer deletes; see lib).
cr_reap_exit_files

name="$(cr_session_name "$label")"
# wait=0: on a direct launch the post-exit output (drained inside cr_launch's
# attach path) just stays in the scrollback above the returning shell prompt —
# no keypress needed (unlike the picker, which redraws over it).
cr_launch "$name" "$attach" 0 -- "$@"
